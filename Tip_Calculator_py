print("Welcome to the tip calculator!")
bill_amount = float(input("What was the total bill ? ₹"))
tip = int(input("How much tip would you like to give ? 10, 12, or 15? "))
tip_as_percent = tip / 100
total_tip_amount = tip_as_percent * bill_amount
total_bill_with_tip = total_tip_amount + bill_amount
split_in_peoples = int(input("How many people to split the bill ? "))
each_person_split = total_bill_with_tip / split_in_peoples
final_split = round(each_person_split, 2)
print(f"Each person should pay: ₹{final_split}")
